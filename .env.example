# ═══════════════════════════════════════════════════════════════
# REQUIRED — The app will fail at runtime if these are not set
# ═══════════════════════════════════════════════════════════════

# Session secret for HMAC token signing (64 hex bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=""

# User credentials as a JSON array
# Each entry needs: email, role ("admin" or "visor"), passwordHash
# Generate password hashes: npx tsx scripts/generate-hash.ts <password>
AUTH_USERS='[
  {"email":"admin@example.com","role":"admin","passwordHash":"salt:hexhash"},
  {"email":"visor@example.com","role":"visor","passwordHash":"salt:hexhash"}
]'

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════

# Local development (SQLite file)
DATABASE_URL="file:persons.db"

# Production — Turso / libsql
# persons_TURSO_DATABASE_URL="libsql://your-db.turso.io"
# persons_TURSO_AUTH_TOKEN="your-jwt-token"
