# Configuración de base de datos para desarrollo local y producción (Turso)

# Desarrollo Local (Usa SQLite local por defecto):
DATABASE_URL="file:persons.db"
DATABASE_AUTH_TOKEN=""

# Producción (Para desplegar en Vercel, copia tus credenciales de Turso aquí):
# DATABASE_URL="libsql://tu-base-de-datos.turso.io"
# DATABASE_AUTH_TOKEN="tu-token-de-autorizacion-jwt"
# (También soporta las variables con el prefijo "persons_TURSO_" que usa tu proyecto)
# persons_TURSO_DATABASE_URL="libsql://tu-base-de-datos.turso.io"
# persons_TURSO_AUTH_TOKEN="tu-token-de-autorizacion-jwt"
